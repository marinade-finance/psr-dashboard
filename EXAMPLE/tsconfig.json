{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "incremental": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "removeComments": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    /* Build output */
    "outDir": "dist",
    "baseUrl": "./",
    "declaration": true,
    "sourceMap": true,
    "declarationMap": true,

    /* Strictness */
    "forceConsistentCasingInFileNames": true,
    "strict": true
  }
}
